<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Surprise...!</title>
    <link rel="stylesheet" type="text/css" href="styles.css">
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600&family=Great+Vibes&display=swap" rel="stylesheet">
</head>
<body>
    <div class="container">
        <h1>Do you think Waguri is cute?</h1>
        
        <img src="waguri.jpg" alt="Waguri Kaoruko" class="waguri-img">
        
        <div class="buttons">
            <button id="no-btn">No</button>
            <button id="yes-btn">Yes, she is cute!</button>
        </div>
        
        <div class="popup" id="popup">
            <p>That's the right answer!</p>
        </div>
    </div>
    <script src="script.js"></script>
</body>
</html>